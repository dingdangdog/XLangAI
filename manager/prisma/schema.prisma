// 与 prisma/migrations 中 PostgreSQL 表结构一致（约定式外键，不在 Prisma 中声明 relation）
// 表名前缀：sys_ 系统/运营配置，usr_ 用户与对话域，bak_ 注销/归档备份

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Language {
  id                String   @id @default(uuid())
  code              String   @unique @db.VarChar(10)
  name              String   @db.VarChar(100)
  nameNative        String?  @map("name_native") @db.VarChar(100)
  /// 试听文案模板，支持 {name} / {{name}} / {{voice_role_name}} 占位符
  previewSampleText String?  @map("preview_sample_text") @db.VarChar(500)
  sortOrder         Int      @default(0) @map("sort_order")
  status            String   @default("active") @db.VarChar(20)
  remark            String?  @db.VarChar(500)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([code])
  @@index([status])
  @@map("sys_languages")
}

model SysLlmServiceConfig {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(200)
  protocol  String   @default("openai") @db.VarChar(50)
  baseUrl   String?  @map("base_url") @db.VarChar(512)
  apiKey    String?  @map("api_key") @db.VarChar(500)
  modelCode String   @map("model_code") @db.VarChar(100)
  config    String?  @db.Text
  status    String   @default("active") @db.VarChar(20)
  sortOrder Int      @default(0) @map("sort_order")
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([protocol])
  @@index([status])
  @@map("sys_llm_service_configs")
}

model SysSttServiceConfig {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(200)
  protocol  String   @default("openai") @db.VarChar(50)
  baseUrl   String?  @map("base_url") @db.VarChar(512)
  apiKey    String?  @map("api_key") @db.VarChar(500)
  modelCode String   @map("model_code") @db.VarChar(100)
  config    String?  @db.Text
  status    String   @default("active") @db.VarChar(20)
  sortOrder Int      @default(0) @map("sort_order")
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([protocol])
  @@index([status])
  @@map("sys_stt_service_configs")
}

/// 翻译服务商配置：机翻 REST 与 OpenAI 兼容 LLM 翻译；全局仅允许一条 status = active。
model SysTranslateServiceConfig {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(200)
  protocol    String   @default("openai") @db.VarChar(50)
  baseUrl     String?  @map("base_url") @db.VarChar(512)
  apiKey      String?  @map("api_key") @db.VarChar(500)
  apiSecret   String?  @map("api_secret") @db.VarChar(500)
  modelCode   String   @map("model_code") @db.VarChar(100)
  llmConfigId String?  @map("llm_config_id") @db.VarChar(36)
  config      String?  @db.Text
  status      String   @default("inactive") @db.VarChar(20)
  sortOrder   Int      @default(0) @map("sort_order")
  remark      String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([protocol])
  @@index([status])
  @@index([llmConfigId])
  @@map("sys_translate_service_configs")
}

/// 对象存储 / 图床：R2、七牛、阿里云 OSS、本地目录；全局仅允许一条 status = active。
model SysObjectStorageConfig {
  id            String   @id @default(uuid())
  code          String   @unique @db.VarChar(100)
  name          String   @db.VarChar(200)
  provider      String   @default("local") @db.VarChar(50)
  baseUrl       String?  @map("base_url") @db.VarChar(512)
  publicBaseUrl String?  @map("public_base_url") @db.VarChar(512)
  apiKey        String?  @map("api_key") @db.VarChar(500)
  secretKey     String?  @map("secret_key") @db.VarChar(500)
  bucket        String?  @db.VarChar(128)
  region        String?  @db.VarChar(64)
  config        String?  @db.Text
  status        String   @default("inactive") @db.VarChar(20)
  sortOrder     Int      @default(0) @map("sort_order")
  remark        String?  @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([provider])
  @@index([status])
  @@map("sys_object_storage_configs")
}

/// 短信服务商配置：阿里云、腾讯云等；全局仅允许一条 status = active。
model SysSmsServiceConfig {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(100)
  name         String   @db.VarChar(200)
  provider     String   @default("aliyun") @db.VarChar(50)
  apiKey       String?  @map("api_key") @db.VarChar(500)
  secretKey    String?  @map("secret_key") @db.VarChar(500)
  region       String?  @db.VarChar(64)
  signName     String?  @map("sign_name") @db.VarChar(100)
  templateCode String?  @map("template_code") @db.VarChar(100)
  config       String?  @db.Text
  status       String   @default("inactive") @db.VarChar(20)
  sortOrder    Int      @default(0) @map("sort_order")
  remark       String?  @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([provider])
  @@index([status])
  @@map("sys_sms_service_configs")
}

/// 系统变量（KEY-VALUE）：登录开关、媒体存储策略等；与厂商密钥表无关。
model SysSystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(128)
  value       String   @db.Text
  valueType   String   @default("string") @map("value_type") @db.VarChar(20)
  /// active：服务端与客户端生效；inactive：忽略库中 value，公共接口不返回
  status      String   @default("active") @db.VarChar(20)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([key])
  @@index([status])
  @@map("sys_system_settings")
}

model TtsServiceConfig {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(200)
  provider  String   @db.VarChar(50)
  baseUrl   String?  @map("base_url") @db.VarChar(512)
  apiKey    String?  @map("api_key") @db.VarChar(500)
  region    String?  @db.VarChar(64)
  modelCode String   @map("model_code") @db.VarChar(100)
  config    String?  @db.Text
  status    String   @default("active") @db.VarChar(20)
  sortOrder Int      @default(0) @map("sort_order")
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([provider])
  @@index([status])
  @@map("sys_tts_service_configs")
}

model VoiceRole {
  id                   String    @id @default(uuid())
  languageId           String?   @map("language_id") @db.VarChar(36)
  /// tts | native_audio_in_text | native_audio_io
  synthesisType        String    @default("tts") @map("synthesis_type") @db.VarChar(30)
  /// native_* 必填；tts 须为空
  llmServiceConfigId   String?   @map("llm_service_config_id") @db.VarChar(36)
  ttsServiceConfigId   String?   @map("tts_service_config_id") @db.VarChar(36)
  voiceCode            String    @map("voice_code") @db.VarChar(50)
  name                 String    @db.VarChar(100)
  gender               String?   @db.VarChar(20)
  /// 角色专属提示词：职业、语气、情绪、风格等；Go 注入系统提示 {{voice_role_prompt}}，亦支持 {{voice_role_name}}、{{target_lang}}
  rolePrompt           String?   @map("role_prompt") @db.Text
  config               String?   @db.Text
  /// 客户端播放用 URL（cloud 为公网地址，server 为 /api/v1/audio/...）
  previewAudioUrl      String?   @map("preview_audio_url") @db.VarChar(500)
  /// 服务器本地副本文件名，便于迁移与 cloud 模式下的本地归档
  previewLocalFilename String?   @map("preview_local_filename") @db.VarChar(200)
  previewGeneratedAt   DateTime? @map("preview_generated_at") @db.Timestamptz(6)
  status               String    @default("active") @db.VarChar(20)
  sortOrder            Int       @default(0) @map("sort_order")
  remark               String?   @db.VarChar(500)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([languageId])
  @@index([synthesisType])
  @@index([llmServiceConfigId])
  @@index([ttsServiceConfigId])
  @@index([status])
  @@map("sys_voice_roles")
}

model PromptTemplate {
  id         String   @id @default(uuid())
  code       String   @unique @db.VarChar(50)
  name       String   @db.VarChar(200)
  content    String   @db.Text
  variables  String?  @db.Text
  languageId String?  @map("language_id") @db.VarChar(36)
  status     String   @default("active") @db.VarChar(20)
  sortOrder  Int      @default(0) @map("sort_order")
  remark     String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([code])
  @@index([status])
  @@map("sys_prompt_templates")
}

/// 口语练习场景（购物、酒店等），关联提示词模板
model PracticeScenario {
  id               String   @id @default(uuid())
  code             String   @unique @db.VarChar(32)
  name             String   @db.VarChar(100)
  nameEn           String?  @map("name_en") @db.VarChar(100)
  icon             String?  @db.VarChar(50)
  description      String?  @db.VarChar(500)
  descriptionEn    String?  @map("description_en") @db.VarChar(500)
  promptTemplateId String?  @map("prompt_template_id") @db.VarChar(36)
  sortOrder        Int      @default(0) @map("sort_order")
  status           String   @default("active") @db.VarChar(20)
  remark           String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([code])
  @@index([status])
  @@map("sys_practice_scenarios")
}

/// 场景开场语模板（按场景 + 语言；{name} 替换为语音角色名）
model ScenarioOpeningLine {
  id           String   @id @default(uuid())
  scenarioCode String   @map("scenario_code") @db.VarChar(32)
  languageCode String   @map("language_code") @db.VarChar(10)
  template     String   @db.VarChar(500)
  status       String   @default("active") @db.VarChar(20)
  remark       String?  @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([scenarioCode, languageCode])
  @@index([scenarioCode])
  @@index([languageCode])
  @@index([status])
  @@map("sys_scenario_opening_lines")
}

/// 跟读练习场景分类（购物、酒店等专项词汇场景，与对话练习场景独立）
model ReadAloudCategory {
  id            String   @id @default(uuid())
  code          String   @unique @db.VarChar(32)
  name          String   @db.VarChar(100)
  nameEn        String?  @map("name_en") @db.VarChar(100)
  icon          String?  @db.VarChar(50)
  description   String?  @db.VarChar(500)
  descriptionEn String?  @map("description_en") @db.VarChar(500)
  sortOrder     Int      @default(0) @map("sort_order")
  status        String   @default("active") @db.VarChar(20)
  remark        String?  @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([code])
  @@index([status])
  @@map("sys_read_aloud_categories")
}

/// 跟读场景在各语言下的展示名（关联 sys_languages.id）
model ReadAloudCategoryLocale {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id") @db.VarChar(36)
  languageId  String   @map("language_id") @db.VarChar(36)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([categoryId, languageId])
  @@index([categoryId])
  @@index([languageId])
  @@map("sys_read_aloud_category_locales")
}

/// 跟读练习词汇（按场景 + 语言；词汇与例句分别生成 TTS 参考音频）
model ReadAloudVocabulary {
  id                         String    @id @default(uuid())
  categoryId                 String    @map("category_id") @db.VarChar(36)
  languageId                 String    @map("language_id") @db.VarChar(36)
  word                       String    @db.VarChar(200)
  exampleSentence            String    @map("example_sentence") @db.VarChar(500)
  voiceRoleId                String    @map("voice_role_id") @db.VarChar(36)
  wordAudioUrl               String?   @map("word_audio_url") @db.VarChar(500)
  wordAudioLocalFilename     String?   @map("word_audio_local_filename") @db.VarChar(200)
  wordAudioGeneratedAt       DateTime? @map("word_audio_generated_at") @db.Timestamptz(6)
  sentenceAudioUrl           String?   @map("sentence_audio_url") @db.VarChar(500)
  sentenceAudioLocalFilename String?   @map("sentence_audio_local_filename") @db.VarChar(200)
  sentenceAudioGeneratedAt   DateTime? @map("sentence_audio_generated_at") @db.Timestamptz(6)
  sortOrder                  Int       @default(0) @map("sort_order")
  status                     String    @default("active") @db.VarChar(20)
  remark                     String?   @db.VarChar(500)
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([categoryId])
  @@index([languageId])
  @@index([categoryId, languageId])
  @@index([status])
  @@map("sys_read_aloud_vocabularies")
}

/// 用户跟读练习会话
model ReadAloudSession {
  id             String    @id @default(uuid())
  userId         String    @map("user_id") @db.VarChar(36)
  categoryId     String    @map("category_id") @db.VarChar(36)
  languageId     String    @map("language_id") @db.VarChar(36)
  status         String    @default("in_progress") @db.VarChar(20)
  totalItems     Int       @default(0) @map("total_items")
  completedItems Int       @default(0) @map("completed_items")
  averageScore   Int?      @map("average_score")
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([status])
  @@map("usr_read_aloud_sessions")
}

/// 跟读练习单次作答（词汇或例句）
model ReadAloudAttempt {
  id            String   @id @default(uuid())
  sessionId     String   @map("session_id") @db.VarChar(36)
  vocabularyId  String   @map("vocabulary_id") @db.VarChar(36)
  /// word | sentence
  part          String   @db.VarChar(20)
  referenceText String   @map("reference_text") @db.VarChar(500)
  transcript    String   @db.Text
  score         Int
  matchDetail   String?  @map("match_detail") @db.Text
  durationMs    Int?     @map("duration_ms")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([sessionId])
  @@index([vocabularyId])
  @@map("usr_read_aloud_attempts")
}

model MembershipTier {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(20)
  name         String   @db.VarChar(100)
  dailyLimit   Int?     @map("daily_limit")
  monthlyLimit Int?     @map("monthly_limit")
  features     String?  @db.Text
  status       String   @default("active") @db.VarChar(20)
  sortOrder    Int      @default(0) @map("sort_order")
  remark       String?  @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([code])
  @@index([status])
  @@map("sys_membership_tiers")
}

model User {
  id                    String    @id @default(uuid())
  phone                 String?   @db.VarChar(20)
  email                 String?   @db.VarChar(255)
  passwordHash          String?   @map("password_hash") @db.VarChar(255)
  nickname              String?   @db.VarChar(100)
  avatarUrl             String?   @map("avatar_url") @db.VarChar(500)
  tierId                String?   @map("tier_id") @db.VarChar(36)
  /// 用户母语（sys_languages.id），用于客户端 STT 双语辅助识别等；与练习会话的目标语言无关。
  languageId            String?   @map("language_id") @db.VarChar(36)
  /// 默认 LLM+TTS 对话使用的 LLM（sys_llm_service_configs.id）；native_audio 模式忽略此项，仍由语音角色的 LLM 决定。
  defaultLlmConfigId    String?   @map("default_llm_config_id") @db.VarChar(36)
  settings              String?   @db.Text
  /// 可抵扣 LLM 对话的 token 余额（与 OpenAI usage.total_tokens 同量纲）；内购消耗型核销时累加。
  tokenBalance          BigInt    @default(0) @map("token_balance")
  /// 当前商店订阅权益到期时间（UTC）；到期后 Go 端在 Principal 中按逻辑回落到免费档额度。
  subscriptionExpiresAt DateTime? @map("subscription_expires_at") @db.Timestamptz(6)
  /// Apple Sign In identityToken 的 `sub`；与密码登录并存时用于关联。
  appleSub              String?   @unique @map("apple_sub") @db.VarChar(255)
  /// Google id_token 的 `sub`。
  googleSub             String?   @unique @map("google_sub") @db.VarChar(255)
  status                String    @default("active") @db.VarChar(20)
  lastLoginAt           DateTime? @map("last_login_at") @db.Timestamptz(6)
  remark                String?   @db.VarChar(500)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tierId])
  @@index([status])
  @@index([phone])
  @@index([email])
  @@map("usr_users")
}

/// 内购商品目录：与 App Store Connect / Google Play 商品 ID 对齐；Go 端 `/api/v1/billing/catalog` 读取。
model BillingProduct {
  id               String   @id @default(uuid()) @db.VarChar(36)
  code             String   @unique @db.VarChar(64)
  /// subscription 或 consumable（与 Go 端校验一致）。
  kind             String   @db.VarChar(32)
  iosProductId     String   @map("ios_product_id") @db.VarChar(200)
  androidProductId String   @map("android_product_id") @db.VarChar(200)
  tierCode         String?  @map("tier_code") @db.VarChar(20)
  tokenGrant       BigInt   @default(0) @map("token_grant")
  sortOrder        Int      @default(0) @map("sort_order")
  status           String   @default("active") @db.VarChar(20)
  remark           String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@map("sys_billing_products")
}

/// 已核销的商店交易（幂等）；唯一键 (platform, store_transaction_id)。
model StoreTransaction {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  userId             String   @map("user_id") @db.VarChar(36)
  platform           String   @db.VarChar(16)
  storeTransactionId String   @map("store_transaction_id") @db.VarChar(512)
  productCode        String   @map("product_code") @db.VarChar(64)
  rawPayload         String?  @map("raw_payload") @db.Text
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([platform, storeTransactionId])
  @@index([userId])
  @@map("usr_store_transactions")
}

model UserUsage {
  id             String   @id @default(uuid())
  userId         String   @map("user_id") @db.VarChar(36)
  date           DateTime @db.Date
  usageCount     Int      @default(0) @map("usage_count")
  tokenCount     Int      @default(0) @map("token_count")
  translateCount Int      @default(0) @map("translate_count")
  translateChars Int      @default(0) @map("translate_chars")
  ttsCount       Int      @default(0) @map("tts_count")
  ttsChars       Int      @default(0) @map("tts_chars")
  sttCount       Int      @default(0) @map("stt_count")
  sttAudioBytes  BigInt   @default(0) @map("stt_audio_bytes")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("usr_user_usage")
}

/// 按 UTC 自然日、服务类型与配置 ID 聚合的系统用量（LLM token / TTS·翻译字符 / STT 音频字节等）。
model SysServiceUsageDaily {
  id           String   @id @default(uuid())
  date         DateTime @db.Date
  serviceType  String   @map("service_type") @db.VarChar(20)
  configId     String   @map("config_id") @db.VarChar(36)
  requestCount Int      @default(0) @map("request_count")
  unitCount    BigInt   @default(0) @map("unit_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([date, serviceType, configId])
  @@index([serviceType, configId, date])
  @@map("sys_service_usage_daily")
}

