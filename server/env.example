PORT=8080
DATABASE_URL=postgresql://postgres:123456@localhost:5432/wlltalk?sslmode=disable
JWT_SECRET=your-secret-key-change-in-production
XLANGAI_DEV_FULL_ACCESS=true
# TTS/STT 响度与转码依赖 ffmpeg（Windows 示例路径，请按本机安装位置修改）
# XLANGAI_FFMPEG_PATH=D:\Program Files\ffmpeg-master-latest-win64-gpl\bin\ffmpeg.exe
# XLANGAI_TTS_TARGET_LUFS=-14
# 可选 Redis：留空则使用进程内内存缓存
# REDIS_URL=redis://localhost:6379/0
# 带密码（requirepass）：redis://:密码@主机:6379/0
# REDIS_URL=redis://:your-password@localhost:6379/0
# 内置音色试听（本地开发通常无需设置，会自动探测 ../manager/storage/audio）
# AUDIO_DIR=../storage/audio
# BUNDLED_AUDIO_DIR=../manager/storage/audio